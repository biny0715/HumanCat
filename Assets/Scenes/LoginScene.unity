  m_Script: {fileID: 11500000, guid: 3f2ca5fa6769ccb49b7d825ad7398507, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CutsceneManager
  cuts:
  - image: {fileID: 21300000, guid: 759690026a754874ca380d8ac9d03f7f, type: 3}
    dialogues:
    - "\uC624\uB298\uB3C4 \uD3C9\uD654\uB85C\uC6B4 \uD558\uB8E8\uC600\uB2E4."
    - "\uC544\uC774\uB4E4\uB3C4 \uAC74\uAC15\uD574 \uBCF4\uC774\uACE0\u2026"
    - "\uC774\uB300\uB85C\uB9CC \uACC4\uC18D\uB418\uBA74 \uC88B\uC744 \uD150\uB370."
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: e701ed162436e45478489c7f52218d44, type: 3}
    dialogues:
    - "\u2026\uC5B4?"
    - "\uC800 \uACE0\uC591\uC774\u2026"
    - "\uC65C \uC800\uB807\uAC8C \uD798\uC774 \uC5C6\uC5B4 \uBCF4\uC774\uC9C0?"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: 19d79cfea037ba64ebea25a80c315ba5, type: 3}
    dialogues:
    - "\uAD1C\uCC2E\uC544\u2026 \uB0B4\uAC00 \uB3C4\uC640\uC904\uAC8C."
    - "\uC870\uAE08\uB9CC \uAE30\uB2E4\uB824\u2026"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: c67ee7febbdcb6d4f86ee14bf5dcb75f, type: 3}
    dialogues:
    - "\uC5B4\u2026?!"
    - "\uC7A0\uAE50\u2014!"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: 93045011c682250479948f1525580857, type: 3}
    dialogues:
    - "\u2026\uBB50\uC9C0\u2026"
    - "\uC55E\uC774\u2026 \uC548 \uBCF4\uC5EC\u2026"
    - "\u2026"
    - "(\uC758\uC2DD\uC774 \uB04A\uC5B4\uC9C4\uB2E4)"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: 66885cb8985ee744c8ea3a139a9bc713, type: 3}
    dialogues:
    - "\u2026\uC5EC\uAE34\u2026"
    - "\uC5B4?"
    - "\uC65C \uC774\uB807\uAC8C\u2026 \uB0AE\uC9C0?"
    - "\u2026\uC774\uAC8C \uBB50\uC57C\u2026"
    - "\uB0B4 \uC190\uC774\u2026 \uC544\uB2C8\uC57C."
    - "\u2026\uC124\uB9C8\u2026"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: 06ec6abe5aa63254da9ac81ad9c71d3d, type: 3}
    dialogues:
    - "\u2026\uC774\uAC74\u2026"
    - "\uB9D0\uB3C4 \uC548 \uB3FC\u2026"
    - "\uB0B4\uAC00\u2026 \uACE0\uC591\uC774\uAC00 \uB41C \uAC70\uC57C\u2026?"
    - "\uB3C4\uB300\uCCB4\u2026 \uBB34\uC2A8 \uC77C\uC774 \uC77C\uC5B4\uB09C \uAC70\uC9C0\u2026"
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
  - image: {fileID: 21300000, guid: ea0509a245d61da448eb2165b4ff0a73, type: 3}
    dialogues:
    - "\u2026?!"
    - "\uBAB8\uC774\u2026 \uB3CC\uC544\uC654\uC5B4\u2026?"
    - "\uC544\uCE68 6\uC2DC\u2026"
    - "\uC124\uB9C8\u2026"
    - "\uBC24\uC774 \uB418\uBA74\u2026 \uB2E4\uC2DC\u2026?"
    - "\uC774\uAC74\u2026 \uADF8\uB0E5 \uC0AC\uACE0\uAC00 \uC544\uB2C8\uC57C."
    - "\uC6B0\uC120\u2026 \uC624\uB298 \uBC24 \uB2E4\uC2DC \uD655\uC778\uD574\uBCF4\uC790."
    fadeInDuration: 0.5
    fadeOutDuration: 0.5
