# Cross-platform line endings: store LF in repo, check out LF on every OS.
* text=auto eol=lf

# Source / config (LF)
*.cs        text eol=lf diff=csharp
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.compute   text eol=lf
*.uss       text eol=lf
*.uxml      text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.rsp       text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf -text
# Unity YAML assets — text, LF, and SmartMerge (UnityYAMLMerge)
*.unity            text eol=lf merge=unityyamlmerge
*.prefab           text eol=lf merge=unityyamlmerge
*.asset            text eol=lf merge=unityyamlmerge
*.meta             text eol=lf merge=unityyamlmerge
*.mat              text eol=lf merge=unityyamlmerge
*.anim             text eol=lf merge=unityyamlmerge
*.controller       text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.mask             text eol=lf merge=unityyamlmerge
*.physicMaterial   text eol=lf merge=unityyamlmerge
*.physicsMaterial2D text eol=lf merge=unityyamlmerge
*.playable         text eol=lf merge=unityyamlmerge
*.preset           text eol=lf merge=unityyamlmerge
*.terrainlayer     text eol=lf merge=unityyamlmerge
*.mixer            text eol=lf merge=unityyamlmerge
*.shadervariants   text eol=lf merge=unityyamlmerge
*.guiskin          text eol=lf merge=unityyamlmerge
*.fontsettings     text eol=lf merge=unityyamlmerge
*.flare            text eol=lf merge=unityyamlmerge
*.brush            text eol=lf merge=unityyamlmerge
*.giparams         text eol=lf merge=unityyamlmerge
*.signal           text eol=lf merge=unityyamlmerge
*.spriteatlas      text eol=lf merge=unityyamlmerge
*.spriteatlasv2    text eol=lf merge=unityyamlmerge
# Windows scripts must keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
# Shell scripts must keep LF
*.sh text eol=lf
# Binary (do not diff/merge as text)
*.dll       binary
*.so        binary
*.dylib     binary
*.bundle    binary
*.a         binary
*.lib       binary
*.pdb       binary
*.mdb       binary
*.exe       binary
*.aar       binary
*.jar       binary
*.class     binary
*.rlib      binary
# Binary assets routed through Git LFS
*.psd       filter=lfs diff=lfs merge=lfs -text
